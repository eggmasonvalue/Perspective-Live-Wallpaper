<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/colorCard"
    android:layout_width="140dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardElevation="2dp"
    app:cardCornerRadius="16dp"
    style="?attr/materialCardViewFilledStyle">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- 16x9 Miniature Wallpaper Preview -->
            <FrameLayout
                android:id="@+id/previewContainer"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="12dp"
                android:padding="8dp">

                <com.perspectivelive.wallpaper.settings.PreviewCanvasView
                    android:id="@+id/previewCanvas"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center" />
            </FrameLayout>

            <TextView
                android:id="@+id/schemeName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Scheme Name" />
        </LinearLayout>

        <!-- Checkmark (when selected) -->
        <TextView
            android:id="@+id/checkmarkIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:text="✓"
            android:textSize="24sp"
            android:textColor="?attr/colorPrimary"
            android:gravity="center"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
